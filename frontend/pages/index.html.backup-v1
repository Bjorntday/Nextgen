<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Shoplive — AI 驱动的电商视频生成平台，上传商品图或链接，几分钟内产出专业视频" />
    <meta name="theme-color" content="#1a3a6e" />
    <link rel="icon" href="/assets/image.png" />
    <title>Shoplive Landing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/styles.css" />
  <style>
    /* 左侧导航栏 - 匹配右侧风格 */
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      width: 64px;
      background: #1a2138;
      border-right: 1px solid rgba(189, 207, 233, 0.25);
      display: flex;
      flex-direction: column;
      padding: 16px 10px;
      z-index: 100;
      transition: width 0.25s ease;
      box-shadow: 4px 0 20px rgba(45, 74, 124, 0.15);
    }
    .sidebar.expanded { width: 200px; }
    .sidebar-toggle {
      width: 44px;
      height: 44px;
      background: transparent;
      border: none;
      border-radius: 10px;
      color: #3d4358;
      font-size: 20px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
      transition: all 0.2s;
    }
    .sidebar-toggle:hover { background: rgba(76, 126, 247, 0.15); color: #4c7ef7; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 6px; flex: 1; }
    .sidebar-nav .nav-item {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      background: transparent;
      border: none;
      border-radius: 10px;
      color: #3d4358;
      font-size: 20px;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
    }
    .sidebar-nav .nav-item:hover { background: rgba(76, 126, 247, 0.15); color: #171a2a; }
    .sidebar-nav .nav-item.active { background: rgba(76, 126, 247, 0.2); color: #4c7ef7; }
    .sidebar-nav .nav-item .nav-label { display: none; font-size: 14px; white-space: nowrap; }
    .sidebar.expanded .nav-item { justify-content: flex-start; padding-left: 16px; width: 180px; }
    .sidebar.expanded .nav-item .nav-label { display: block; }
    .sidebar.expanded .nav-item .nav-icon { margin-right: 12px; }
    /* 侧边栏内的用户状态 */
    .sidebar-user {
      margin-top: auto;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.2s;
      color: #3d4358;
      font-size: 13px;
    }
    .sidebar-user:hover { background: rgba(76, 126, 247, 0.15); }
    .sidebar-user.logged { color: #4caf6e; }
    .sidebar-user .user-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #f0b429;
      margin-right: 0;
    }
    .sidebar-user.logged .user-dot { background: #4caf6e; }
    .sidebar-user .nav-label { display: none; }
    .sidebar.expanded .sidebar-user { justify-content: flex-start; padding-left: 16px; }
    .sidebar.expanded .sidebar-user .nav-label { display: block; margin-left: 8px; }
    .sidebar.expanded .sidebar-user .user-dot { margin-right: 12px; }
    /* 主体偏移 */
    .sidebar-open .hero-shell { margin-left: 64px; transition: margin-left 0.25s ease; }
    .sidebar-open.sidebar-expanded .hero-shell { margin-left: 200px; }
  </style>
  </head>
  <body class="landing-body">
  <!-- 左侧导航栏 -->
  <aside class="sidebar" id="sidebar">
    <button class="sidebar-toggle" id="sidebarToggle" title="展开/收起导航">‹</button>
    <nav class="sidebar-nav">
      <a href="#" class="nav-item active" data-page="video">
        <span class="nav-icon">🎬</span>
        <span class="nav-label">视频</span>
      </a>
      <a href="#" class="nav-item" data-page="product">
        <span class="nav-icon">📦</span>
        <span class="nav-label">商品</span>
      </a>
      <a href="#" class="nav-item" data-page="image">
        <span class="nav-icon">🖼️</span>
        <span class="nav-label">图片</span>
      </a>
      <a href="#" class="nav-item" data-page="settings">
        <span class="nav-icon">⚙️</span>
        <span class="nav-label">设置</span>
      </a>
    </nav>
    <!-- 侧边栏内用户状态 -->
    <div class="sidebar-user" id="sidebarUser">
      <span class="user-dot"></span>
      <span class="nav-label" id="userText">游客</span>
    </div>
  </aside>

  <main class="landing-page">
  <script>
  (function(){
    var E=function(msg){var d=document.getElementById('__err');if(!d){d=document.createElement('div');d.id='__err';d.style.cssText='position:fixed;top:0;left:0;right:0;background:#c00;color:#fff;z-index:999999;padding:12px 16px;font:13px/1.5 monospace;word-break:break-all;white-space:pre-wrap;';document.body.appendChild(d);}d.textContent+=msg+'\n';};
    window.addEventListener('error',function(e){E('JS ERROR: '+e.message+'\n  at '+e.filename+':'+e.lineno);});
    window.addEventListener('unhandledrejection',function(e){E('PROMISE REJECT: '+(e.reason&&e.reason.message?e.reason.message:String(e.reason)));});
  })();
  </script>
    <main class="landing-page">
      <section class="hero-shell">
        <div class="hero-inner">
        <header class="topbar">
          <div class="brand">
            <img class="brand-logo" src="/assets/image.png" alt="Shoplive logo" />
            <div class="brand-signature">
              <div class="brand-text">
                <strong>SHOPLIVE</strong>
                <span>STUDIO</span>
              </div>
              <span class="brand-badge" data-i18n="brandBadge">AI 视频工作台</span>
            </div>
          </div>
          <nav class="nav">
            <a href="#" class="nav-link is-active" data-i18n="navFeatures">Features</a>
            <a href="#" class="nav-link" data-i18n="navSolutions">Solutions</a>
            <a href="#" class="nav-link" data-i18n="navResources">Resources</a>
            <a href="#" class="nav-link" data-i18n="navPricing">Pricing</a>
            <a href="#" class="nav-link" data-i18n="navCommunity">Community</a>
          </nav>
          <div class="top-actions">
            <button id="langToggleBtn" class="lang-btn">
              <span class="lang-globe" aria-hidden="true">◉</span>
              <span class="lang-label">EN</span>
            </button>
            <a href="javascript:void(0)" class="start-btn" id="loginBtn">登录</a>
            <button id="topStartBtn" class="start-btn" data-i18n="start">Get started</button>
          </div>
        </header>

        <div class="hero-panel">
          <div class="left-copy">
            <div class="hero-kicker" data-i18n="heroKicker">面向电商团队的 AI 视频工作台</div>
            <h1 class="hero-title">
              <span class="hero-line hero-line-strong" data-i18n="heroLine2">把想法直接变成视频。</span>
            </h1>
          </div>
        </div>

        <div class="section-divider" aria-hidden="true"></div>

        <div class="input-row input-row-smart">
          <div class="command-bar-head">
            <div class="command-bar-kicker" data-i18n="commandBarKicker">从参考图、商品链接或一句提示词开始</div>
            <div class="command-bar-status">
              <span class="command-status-chip" data-i18n="commandStatus1">自动识别商品</span>
              <span class="command-status-chip" data-i18n="commandStatus2">自动路由模型</span>
            </div>
          </div>
          <div class="input-main">
            <button id="openRefPanelBtn" class="ref-trigger" type="button">
              <span class="ref-icon" aria-hidden="true"></span>
              <span data-i18n="uploadRef">参考图</span>
            </button>
            <input id="promptInput" placeholder="Choose one to start with" />
            <button id="startFlowBtn" class="primary-btn" data-i18n="cta">Get free videos</button>
          </div>
          <div class="creators-row">
            <div class="creator-avatars" aria-hidden="true">
              <img src="../assets/images/creator-1.jpg" alt="" />
              <img src="../assets/images/creator-2.jpg" alt="" />
              <img src="../assets/images/creator-3.jpg" alt="" />
            </div>
            <span class="creator-stat">
              <strong class="creator-stat-num" data-i18n="creatorNum">10,000+</strong>
              <span class="creator-stat-label" data-i18n="creatorLabel">创作者正在使用</span>
            </span>
            <div class="creator-ticker" aria-label="User quotes" aria-live="off">
              <div class="creator-ticker-track">
                <span class="creator-ticker-item" data-i18n="quote1">"一句提示词，生成质感不输拍摄的商品视频" — 李 ×，女装买手</span>
                <span class="creator-ticker-item" data-i18n="quote2">"解放了我们整个内容团队" — 王 ×，品牌运营</span>
                <span class="creator-ticker-item" data-i18n="quote3">"从链接到成片只需 3 分钟" — 陈 ×，独立卖家</span>
                <span class="creator-ticker-item" aria-hidden="true" data-i18n="quote1">"一句提示词，生成质感不输拍摄的商品视频" — 李 ×，女装买手</span>
                <span class="creator-ticker-item" aria-hidden="true" data-i18n="quote2">"解放了我们整个内容团队" — 王 ×，品牌运营</span>
                <span class="creator-ticker-item" aria-hidden="true" data-i18n="quote3">"从链接到成片只需 3 分钟" — 陈 ×，独立卖家</span>
              </div>
            </div>
          </div>
          <div class="input-advanced" id="landingAdvanced">
            <div class="adv-ops">
              <label>
                <span data-i18n="durationLabel">视频时长</span>
                <select id="durationSelect">
                  <option value="8">8秒</option>
                  <option value="6">6秒</option>
                  <option value="4">4秒</option>
                  <option value="16">16秒</option>
                </select>
              </label>
              <button id="enhancePromptBtn" class="secondary-btn" data-i18n="enhancePrompt">提示词增强</button>
            </div>
          </div>
        </div>
        <p class="landing-note" data-i18n="uploadHint">上传商品图，描述你的商品信息和想要的视频风格…</p>
        <section class="template-section" aria-label="Explore templates">
          <div class="template-head">
            <strong class="template-title">探索模板</strong>
          </div>
          <div class="command-template-grid" aria-label="Quick prompt templates">
            <button type="button" class="command-template-card is-active" data-color="indigo" data-fill-zh="为女装上新做一条短视频，突出版型、垂感和通勤氛围。" data-fill-en="Create a launch short video for women's apparel, highlighting silhouette, drape, and commuter mood." data-duration="8">
              <span class="template-thumb">
                <img src="../assets/images/template-01.jpg" alt="模板01封面" />
              </span>
              <span class="command-template-tag" data-i18n="commandTemplateTag1">模板 01</span>
              <strong data-i18n="commandTemplateTitle1">女装上新</strong>
              <small data-i18n="commandTemplateDesc1">适合新品发布、通勤穿搭和面料氛围表达</small>
            </button>
            <button type="button" class="command-template-card" data-color="slate" data-fill-zh="为黑色跑鞋做一条材质细节特写视频，突出鞋底科技感和脚感支撑。" data-fill-en="Create a material-detail video for black running shoes, focusing on sole tech and support." data-duration="8">
              <span class="template-thumb">
                <img src="../assets/images/template-02.jpg" alt="模板02封面" />
              </span>
              <span class="command-template-tag" data-i18n="commandTemplateTag2">模板 02</span>
              <strong data-i18n="commandTemplateTitle2">黑色跑鞋细节</strong>
              <small data-i18n="commandTemplateDesc2">适合材质展示、鞋底科技感和镜头推进</small>
            </button>
            <button type="button" class="command-template-card" data-color="rose" data-fill-zh="生成一条适合社媒投放的商品短视频，镜头节奏快，突出卖点和价格记忆点。" data-fill-en="Generate a social-ready product short video with fast pacing, clear selling points, and price recall." data-duration="6">
              <span class="template-thumb">
                <img src="../assets/images/template-03.jpg" alt="模板03封面" />
              </span>
              <span class="command-template-tag" data-i18n="commandTemplateTag3">模板 03</span>
              <strong data-i18n="commandTemplateTitle3">社媒投放短视频</strong>
              <small data-i18n="commandTemplateDesc3">适合快节奏转化、卖点记忆和广告投放</small>
            </button>
          </div>
        </section>
        </div><!-- /.hero-inner -->
      </section>
    </main>

    <section id="refModal" class="ref-modal" aria-hidden="true">
      <div class="ref-modal-card">
        <header class="ref-modal-head">
          <strong data-i18n="refPanelTitle">选择参考图</strong>
          <button id="closeRefPanelBtn" class="ref-close-btn" type="button" aria-label="Close">×</button>
        </header>
        <div class="ref-modal-body">
          <aside class="ref-modal-side">
            <button id="refUploadBtn" class="ref-side-btn" type="button">
              <span class="side-icon upload" aria-hidden="true"></span>
              <span data-i18n="refUploadLocal">从本地上传</span>
            </button>
            <button id="refMosaicBtn" class="ref-side-btn" type="button">
              <span class="side-icon mosaic" aria-hidden="true"></span>
              <span data-i18n="refUploadMosaic">从本地上传拼图</span>
            </button>
            <input id="refFileInput" type="file" accept="image/*" multiple hidden />
          </aside>
          <div class="ref-modal-main">
            <div class="ref-tabs">
              <button id="refTabUpload" class="ref-tab is-active" type="button" data-i18n="refTabUpload">上传资产</button>
              <button id="refTabAi" class="ref-tab" type="button" data-i18n="refTabAi">AI 生成</button>
            </div>
            <div id="refUploadPanel" class="ref-panel is-active">
              <div id="refUploadGrid" class="ref-grid"></div>
            </div>
            <div id="refAiPanel" class="ref-panel">
              <div class="ai-form-box">
                <p class="ai-form-hint" data-i18n="aiFormHint">填写 1–3 项 · AI 自动优化提示词并生成图片</p>
                <div class="ai-form-fields">
                  <div class="ai-form-field">
                    <label class="ai-form-label" for="aiFieldRegion" data-i18n="aiFieldRegionLabel">模特地区</label>
                    <div class="ai-form-input-wrap">
                      <input id="aiFieldRegion" type="text" class="ai-form-input"
                        data-i18n-placeholder="aiFieldRegionPh"
                        placeholder="如：日本、欧美、东南亚…" />
                      <div class="ai-form-chips" data-field="region">
                        <button type="button" class="ai-chip" data-value="欧美">欧美</button>
                        <button type="button" class="ai-chip" data-value="日本">日本</button>
                        <button type="button" class="ai-chip" data-value="东南亚">东南亚</button>
                        <button type="button" class="ai-chip" data-value="中东">中东</button>
                      </div>
                    </div>
                  </div>
                  <div class="ai-form-field">
                    <label class="ai-form-label" for="aiFieldCategory" data-i18n="aiFieldCategoryLabel">主营品类</label>
                    <div class="ai-form-input-wrap">
                      <input id="aiFieldCategory" type="text" class="ai-form-input"
                        data-i18n-placeholder="aiFieldCategoryPh"
                        placeholder="如：连衣裙、运动鞋、手提包…" />
                      <div class="ai-form-chips" data-field="category">
                        <button type="button" class="ai-chip" data-value="连衣裙">连衣裙</button>
                        <button type="button" class="ai-chip" data-value="运动鞋">运动鞋</button>
                        <button type="button" class="ai-chip" data-value="手提包">手提包</button>
                        <button type="button" class="ai-chip" data-value="T恤">T恤</button>
                      </div>
                    </div>
                  </div>
                  <div class="ai-form-field">
                    <label class="ai-form-label" for="aiFieldStyle" data-i18n="aiFieldStyleLabel">风格</label>
                    <div class="ai-form-input-wrap">
                      <input id="aiFieldStyle" type="text" class="ai-form-input"
                        data-i18n-placeholder="aiFieldStylePh"
                        placeholder="如：简约高级感、街头潮流、法式优雅…" />
                      <div class="ai-form-chips" data-field="style">
                        <button type="button" class="ai-chip" data-value="简约高级感">高级感</button>
                        <button type="button" class="ai-chip" data-value="街头潮流">街头潮流</button>
                        <button type="button" class="ai-chip" data-value="法式优雅">法式优雅</button>
                        <button type="button" class="ai-chip" data-value="日系清新">日系清新</button>
                      </div>
                    </div>
                  </div>
                </div>
                <button id="refAiGenerateBtn" class="ai-gen-submit-btn" type="button">
                  <span class="ai-gen-submit-icon">✦</span>
                  <span data-i18n="refAiGenerateBtn">AI 生成</span>
                </button>
              </div>
              <div id="refAiResultGrid" class="ref-grid"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script type="module" src="/scripts/entry/landing.main.js?v=20260309b"></script>

    <script>
      // 左侧导航交互
      const sidebar = document.getElementById('sidebar');
      const sidebarToggle = document.getElementById('sidebarToggle');
      const navItems = sidebar.querySelectorAll('.nav-item');
      const sidebarUser = document.getElementById('sidebarUser');
      const userText = document.getElementById('userText');

      // 登录状态
      let isLoggedIn = localStorage.getItem('shoplive_token') === 'logged_in';
      let currentUser = localStorage.getItem('shoplive_user') || '';

      // 更新状态显示
      function updateUserStatus() {
        if (isLoggedIn && currentUser) {
          sidebarUser.classList.add('logged');
          userText.textContent = currentUser;
        } else {
          sidebarUser.classList.remove('logged');
          userText.textContent = '游客';
        }
      }
      updateUserStatus();

      // 收起/展开
      sidebarToggle.addEventListener('click', () => {
        const isExpanded = sidebar.classList.toggle('expanded');
        document.body.classList.toggle('sidebar-open', true);
        document.body.classList.toggle('sidebar-expanded', isExpanded);
        sidebarToggle.style.transform = isExpanded ? 'rotate(180deg)' : '';
      });

      // 导航点击高亮
      navItems.forEach(item => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          navItems.forEach(i => i.classList.remove('active'));
          item.classList.add('active');
        });
      });

      // 点击用户状态登录/退出
      sidebarUser.addEventListener('click', () => {
        if (isLoggedIn) {
          if (confirm('确定退出登录？')) {
            isLoggedIn = false;
            currentUser = '';
            localStorage.removeItem('shoplive_token');
            localStorage.removeItem('shoplive_user');
            updateUserStatus();
          }
        } else {
          // 显示登录面板
          showLoginPanel();
        }
      });

      // 显示登录面板
      function showLoginPanel() {
        // 检查是否已有面板
        let panel = document.getElementById('loginPanel');
        if (panel) {
          panel.style.display = 'flex';
          return;
        }

        // 创建登录面板（居中显示）
        panel = document.createElement('div');
        panel.id = 'loginPanel';
        panel.style.cssText = `
          position: fixed;
          left: 50%;
          top: 50%;
          transform: translate(-50%, -50%);
          width: 320px;
          padding: 24px;
          background: rgba(26, 33, 56, 0.98);
          border: 1px solid rgba(189, 207, 233, 0.25);
          border-radius: 16px;
          z-index: 1000;
          display: flex;
          flex-direction: column;
          gap: 14px;
          box-shadow: 0 20px 50px rgba(45, 74, 124, 0.3);
          backdrop-filter: blur(20px);
        `;
        panel.innerHTML = `
          <div style="text-align: center; margin-bottom: 8px;">
            <div style="font-size: 24px; margin-bottom: 4px;">🎬</div>
            <div style="font-size: 16px; color: #e2e8f0; font-weight: 600;">登录 SHOPLIVE</div>
            <div style="font-size: 12px; color: #64748b;">输入账户信息继续</div>
          </div>
          <input type="text" id="loginUsername2" placeholder="用户名" style="padding: 12px 16px; background: rgba(42, 54, 80, 0.8); border: 1px solid rgba(189, 207, 233, 0.2); border-radius: 10px; color: #e2e8f0; font-size: 14px;" />
          <input type="password" id="loginPassword2" placeholder="密码" style="padding: 12px 16px; background: rgba(42, 54, 80, 0.8); border: 1px solid rgba(189, 207, 233, 0.2); border-radius: 10px; color: #e2e8f0; font-size: 14px;" />
          <button id="loginSubmit2" style="padding: 12px; background: linear-gradient(135deg, #4c7ef7, #3b6de6); border: none; border-radius: 10px; color: white; font-size: 14px; font-weight: 600; cursor: pointer;">登录</button>
          <div style="text-align: center; font-size: 12px; color: #64748b;">
            登录后享受完整功能
          </div>
        `;
        document.body.appendChild(panel);

        // 绑定登录事件
        document.getElementById('loginSubmit2').addEventListener('click', () => {
          const username = document.getElementById('loginUsername2').value.trim();
          const password = document.getElementById('loginPassword2').value;
          if (username && password) {
            isLoggedIn = true;
            currentUser = username;
            localStorage.setItem('shoplive_token', 'logged_in');
            localStorage.setItem('shoplive_user', username);
            updateUserStatus();
            panel.style.display = 'none';
          }
        });

        // 点击面板外关闭
        document.addEventListener('click', function closePanel(e) {
          if (!panel.contains(e.target) && e.target !== userStatus) {
            panel.style.display = 'none';
            document.removeEventListener('click', closePanel);
          }
        });
      }

      // 顶部登录按钮
      const loginBtn = document.getElementById('loginBtn');
      if (loginBtn) {
        loginBtn.addEventListener('click', (e) => {
          e.preventDefault();
          if (!isLoggedIn) {
            showLoginPanel();
          }
        });
      }
    </script>
  </body>
</html>
