# ══════════════════════════════════════════════════
# 九天云盒 Pro — .env 配置模板
# 盒子出厂时预配，用户可在设置页修改
# ══════════════════════════════════════════════════

# ── 盒子标识（出厂烧录，不可修改）──
BOX_ID=box-000001
BOX_MODEL=nextgen-pro

# ── 内置即梦 API（出厂预配，开箱即用）──
JIMENG_API_KEY=default-key-xxx
JIMENG_API_BASE=http://43.163.110.48

# ── 内置额度 ──
# 出厂赠送 100 张图 / 10 个视频
QUOTA_IMAGE_TOTAL=100
QUOTA_VIDEO_TOTAL=10
# 已使用（由系统自动更新）
QUOTA_IMAGE_USED=0
QUOTA_VIDEO_USED=0

# ── LLM API（可选，用户自己在设置页配）──
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_MODEL=

# ── 服务端口 ──
PORT=8000

# ── 分发发布（自动上传到社媒平台）──
# headless 模式在设置页->平台账号管理中按平台配置
# Cookie 文件存储目录（相对于项目根目录）
PUBLISH_COOKIES_DIR=backend/distribution/cookies
# Chrome 浏览器路径（留空自动使用 patchright 内置 Chromium）
LOCAL_CHROME_PATH=
# 发布操作超时秒数
PUBLISH_BROWSER_TIMEOUT=180
